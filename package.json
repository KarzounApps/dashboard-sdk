{
  "name": "@octobots/dashboard-sdk",
  "version": "1.0.0",
  "description": "Lightweight SDK for building Octobots dashboard panel apps. Provides a typed postMessage bridge for executing miniapp actions, receiving conversation/customer context, and triggering host UI actions from sandboxed iframes.",
  "author": "KarzounApps",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "octobots",
    "dashboard",
    "iframe",
    "sdk",
    "miniapps",
    "postmessage",
    "karzoun"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/KarzounApps/dashboard-sdk.git"
  },
  "homepage": "https://github.com/KarzounApps/dashboard-sdk#readme",
  "bugs": {
    "url": "https://github.com/KarzounApps/dashboard-sdk/issues"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
